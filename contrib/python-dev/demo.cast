[65.425048, "o", "apiVersion: batch/v1\r\nkind: Job\r\nmetadata:\r\n  name: python-dev-sandbox\r\n  namespace: default\r\n  labels:\r\n    app: nono-demo\r\n    profile: default\r\n    mode: sandbox\r\nspec:\r\n  backoffLimit: 0\r\n  ttlSecondsAfterFinished: 300\r\n  template:\r\n    metadata:\r\n      annotations:\r\n        # default profile: Landlock filesystem isolation (works with nono wrap / direct mode).\r\n        # Note: python-dev/node-dev/go-dev profiles enable network proxy filtering\r\n        # which requires nono run (supervisor mode), not nono wrap (direct mode).\r\n        nono.sh/profile: \"default\"\r\n    spec:\r\n      runtimeClassName: nono-sandbox\r\n      restartPolicy: Never\r\n      containers:\r\n        - name: demo\r\n          image: nono-demo-python:latest\r\n"]
