[58.653301, "o", "============================================"]
[58.653584, "o", "\r\n Mode: BASELINE (no runtimeClassName)\r\n No sandbox — full container access\r\n============================================\r\n\r\n--- attack surface (expected: ALLOWED without sandbox) ---\r\n  write /etc/hosts (host poisoning)                 ALLOWED\r\n  write /usr/local/bin/exploit (backdoor)           ALLOWED\r\n  read /etc/shadow (credential theft)               ALLOWED\r\n  read /etc/passwd (user enumeration)               ALLOWED\r\n  write site-packages/evil.py (pkg inject)          ALLOWED\r\n\r\n--- python-dev runtime (expected: ALLOWED) ---\r\n  python3 --version                                 ALLOWED\r\n  python3 -c print                                  ALLOWED\r\n  write /tmp/workfile                               ALLOWED\r\n\r\nDone.\r\n"]
[61.668118, "o", "\r\n\r\n\u001b[1m\u001b[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n\u001b[1m\u001b[1;36m  3 · nono Sandbox — Landlock filesystem isolation\u001b[0m\r\n\u001b[1m\u001b[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n\r\n"]
