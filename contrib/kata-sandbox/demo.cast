[26.466718, "o", "\u001b[1m\u001b[1;37m\r\n   ┌──────────────────────────────────────────────────────────────────────────┐\r\n   │                                                                          │\r\n   │   nono-nri · Kata Containers sandbox demo                               │\r\n   │                                                                          │\r\n   │   Runtime  : containerd 2.2.1 + NRI + kata-deploy                       │\r\n   │   Sandbox  : Kata QEMU/KVM micro-VM  +  nono Landlock isolation         │\r\n   │   Approach : nono bind-mounted from host via virtiofs (no initrd embed) │\r\n   │                                                                          │\r\n   └──────────────────────────────────────────────────────────────────────────┘\r\n\u001b[0m\r\n"]
