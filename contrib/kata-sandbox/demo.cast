[112.782244, "o", "\r\n\r\n\u001b[1m\u001b[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n\u001b[1m\u001b[1;36m  Summary\u001b[0m\r\n\u001b[1m\u001b[1;36m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\u001b[0m\r\n\r\n"]
[113.285994, "o", "\r\n  \u001b[1m\u001b[1;37mOperation                                     plain pod         kata-nono-sandbox   \u001b[0m\r\n"]
[113.287457, "o", "  \u001b[2m──────────────────────────────────────────────────────────────────────────────────\u001b[0m\r\n"]
[113.287867, "o", "  \u001b[2mecho \"...\" >> /etc/hosts                    \u001b[0m  \u001b[1;32mALLOWED         \u001b[0m  \u001b[1;31mBLOCKED (Landlock)  \u001b[0m\r\n"]
[113.287994, "o", "  \u001b[2mhead /etc/shadow                            \u001b[0m  \u001b[1;32mALLOWED         \u001b[0m  \u001b[1;31mBLOCKED (Landlock)  \u001b[0m"]
[113.288662, "o", "\r\n  \u001b[2mcp /bin/sh /usr/local/bin/x                 \u001b[0m  \u001b[1;32mALLOWED         \u001b[0m  \u001b[1;31mBLOCKED (Landlock)  \u001b[0m\r\n"]
[113.290372, "o", "  \u001b[2m──────────────────────────────────────────────────────────────────────────────────\u001b[0m\r\n  \u001b[2mpython3 -c 'print(...)'                     \u001b[0m  \u001b[1;32mALLOWED         \u001b[0m  \u001b[1;32mALLOWED             \u001b[0m\r\n"]
[113.290482, "o", "  \u001b[2mecho \"ok\" > /tmp/work                       \u001b[0m  \u001b[1;32mALLOWED         \u001b[0m  \u001b[1;32mALLOWED             \u001b[0m\r\n\r\n  \u001b[2mVM isolation (Kata QEMU/KVM)  +  Landlock filesystem sandboxing (nono)\u001b[0m\r\n"]
[113.290576, "o", "  \u001b[2mnono binary delivered into VM via virtiofs bind-mount — no initrd embed\u001b[0m\r\n\r\n"]
[113.292943, "o", "\u001b[2m────────────────────────────────────────────────────────────────────────────────\u001b[0m\r\n"]
