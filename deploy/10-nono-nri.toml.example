# nono-nri plugin configuration
# Install as: /etc/nri/conf.d/10-nono-nri.toml
#
# runtime_classes: list of RuntimeClass *handler* names to intercept
#   (matches pod.GetRuntimeHandler(), not metadata.name).
#   Pods whose RuntimeClass handler matches any entry get nono injection.
#   All other pods are skipped (no-op).
#
# default_profile: nono profile used when pod lacks nono.sh/profile annotation.
#
# nono_bin_path: absolute path to the nono binary on the HOST node.
#   The DaemonSet init container copies nono here from the image.
#   This path is bind-mounted into sandboxed containers.
#   Not required when all handlers are listed in vm_rootfs_classes.
#
# socket_path: NRI socket path. Empty string uses the NRI default
#   (/var/run/nri/nri.sock).
#
# vm_rootfs_classes: list of RuntimeClass handler names whose Kata VMs have
#   nono pre-installed in the guest rootfs at /nono/nono (e.g. using the
#   kata-rootfs-nono image). For these handlers the per-container host
#   bind-mount is skipped and NONO_PROFILE is injected as an env var instead,
#   so shell wrapper scripts invoked via kubectl exec can apply the correct
#   profile. nono_bin_path is still required for handlers NOT in this list.

runtime_classes = ["nono-runc"]
default_profile = "default"
nono_bin_path = "/opt/nono-nri/nono"
socket_path = ""
# seccomp_profile: seccomp policy injected into every sandboxed container.
#   "restricted"      RuntimeDefault minus io_uring_*, ptrace, seccomp syscall,
#                     and pidfd_getfd. Recommended for untrusted AI workloads.
#   "runtime-default" Docker RuntimeDefault allowlist verbatim.
#   ""                Disabled; no seccomp policy injected by nono-nri.
# For Kata handlers, requires disable_guest_seccomp = false in the QEMU config
# (set automatically by the kubefence kata-setup DaemonSet).
seccomp_profile = "restricted"
# vm_rootfs_classes = []
